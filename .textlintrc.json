{
  "plugins": {},
  "filters": {
    "comments": true
  },
  "rules": {
    "preset-ja-technical-writing": {
      "no-exclamation-question-mark": false,
      "ja-no-mixed-period": {
        "allowPeriodMarks": [":::"]
      },
      "ja-no-weak-phrase": false,
      "sentence-length": {
        "max": 130
      }
    }
  }
}
